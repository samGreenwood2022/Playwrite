{
  "name": "playwrite",
  "version": "1.0.0",
  "description": "Playwrite project",
  "main": "dist/index.js",
  "scripts": {
    "codegen": "npx playwright codegen https://source.thenbs.com/",
    "cucumber": "cucumber-js --require-module ts-node/register --require tests/features/support/*.ts --require tests/step_definitions/*.ts tests/features/*.feature --parallel 2 --format html:reports/cucumber-report.html",
    "smoke": "cucumber-js --require-module ts-node/register --require tests/features/support/*.ts --require tests/step_definitions/*.ts tests/features/*.feature --tags @smoke --parallel 2 --format html:reports/cucumber-smoke-report.html",
    "regression": "cucumber-js --require-module ts-node/register --require tests/features/support/*.ts --require tests/step_definitions/*.ts tests/features/*.feature --tags @regression --parallel 2 --format html:reports/cucumber-regression-report.html",
    "cucumberx10": "node scripts/run-cucumber-times.mjs 10",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "author": "S Greenwood",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cucumber/cucumber": "^12.8.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "axe-html-reporter": "^2.2.11",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "lighthouse": "^13.2.0",
    "pixelmatch": "^7.1.1",
    "playwright-lighthouse": "^4.0.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
