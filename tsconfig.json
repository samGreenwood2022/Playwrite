  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*.ts",
    "playwright.config.ts"
  ]
}